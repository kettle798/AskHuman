        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/node \"/Users/wutian/Developer/HumanInLoop/demo/agent-lifecycle/harness/hooklog.cjs\" claude UserPromptSubmit project"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
