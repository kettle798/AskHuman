{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认权限：作用于运行时创建的所有窗口",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-always-on-top",
    "core:window:allow-close",
    "drag:default",
    "liquid-glass:default"
  ]
}
